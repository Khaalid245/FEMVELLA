# Django
SECRET_KEY=your-secret-key-minimum-50-characters-long-replace-this-now
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Database
DATABASE_URL=mysql://femvelle:femvelle@mysql:3306/femvelle

# Redis
REDIS_URL=redis://redis:6379/0
USE_REDIS_CACHE=True
REDIS_MAX_CONNECTIONS=50
CACHE_DEFAULT_TIMEOUT=300
API_CACHE_TIMEOUT=900
QUERY_CACHE_TIMEOUT=600
LONGTERM_CACHE_TIMEOUT=86400

# Phase 2 performance and search
SEARCH_BACKEND=database
ELASTICSEARCH_URL=http://elasticsearch:9200
PERFORMANCE_MONITORING_ENABLED=True
TRACK_API_RESPONSES=True
REQUEST_LOG_SAMPLE_RATE=0.1
REDACTED_QUERY_PARAMS=token,access,refresh,password,secret,signature,email
PERFORMANCE_EXCLUDED_PATH_PREFIXES=/static/,/media/,/__debug__/
SLOW_REQUEST_THRESHOLD=2.0
SLOW_QUERY_THRESHOLD=0.5
USE_READ_REPLICA=False
DB_CONN_MAX_AGE=300

# Security hardening
CSP_ALLOW_UNSAFE_INLINE=False
MAX_PRODUCT_IMAGE_COUNT=5
THROTTLE_SEARCH=120/min
THROTTLE_SEARCH_CLICK=30/min

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_with_your_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_secret
STRIPE_CURRENCY=usd

# Email
EMAIL_HOST=smtp.yourmailprovider.com
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
ADMIN_NOTIFICATION_EMAILS=
FRONTEND_URL=https://yourdomain.com

# Exchange rates (optional — uses free tier if blank)
EXCHANGE_RATE_API_KEY=

MYSQL_USER=femvelle
MYSQL_PASSWORD=femvelle
MYSQL_ROOT_PASSWORD=rootpassword
