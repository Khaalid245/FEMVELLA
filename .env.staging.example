# Staging Environment Variables
# Copy to .env.staging and fill in values

# Django
SECRET_KEY=staging-secret-key-change-this
DEBUG=False
ALLOWED_HOSTS=staging.femvelle.com,api.staging.femvelle.com
DJANGO_SETTINGS_MODULE=config.settings.staging

# Database (separate staging DB)
DB_NAME=femvelle_staging
DB_USER=femvelle
DB_PASSWORD=staging-db-password
DB_ROOT_PASSWORD=staging-root-password
DB_HOST=mysql
DB_PORT=3306

# Redis
REDIS_PASSWORD=staging-redis-password

# AWS S3 (staging bucket)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=femvelle-staging
AWS_S3_REGION_NAME=us-east-1

# Sentry (same project, different environment tag)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
FRONTEND_SENTRY_DSN=https://your-frontend-sentry-dsn@sentry.io/project-id

# Stripe (TEST keys for staging)
STRIPE_SECRET_KEY=sk_test_your-stripe-test-key
STRIPE_PUBLIC_KEY_TEST=pk_test_your-stripe-test-key
STRIPE_WEBHOOK_SECRET=whsec_your-test-webhook-secret

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=staging@femvelle.com
EMAIL_HOST_PASSWORD=your-email-password

# Container registry
REGISTRY=ghcr.io/your-org/femvelle
IMAGE_TAG=staging

# Release
RELEASE_VERSION=staging

# Feature flags (staging enables unreleased features)
FF_NEW_CHECKOUT=true
FF_RECOMMENDATIONS=true
FF_ANALYTICS_V2=true
FF_SEARCH_V2=true
FF_WISHLIST_SHARING=true
FF_LOYALTY_PROGRAM=false

# Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/your-staging-webhook
