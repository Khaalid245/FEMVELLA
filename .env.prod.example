# Production Environment Variables for Femvelle
# Copy this file to .env and fill in the actual values

# Django
SECRET_KEY=your-super-secret-key-here-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=femvelle.com,www.femvelle.com,api.femvelle.com

# Database
DB_NAME=femvelle_prod
DB_USER=femvelle
DB_PASSWORD=your-secure-database-password
DB_ROOT_PASSWORD=your-secure-root-password
DB_HOST=mysql
DB_PORT=3306

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=your-secure-redis-password

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=femvelle-media
AWS_S3_REGION_NAME=us-east-1
BACKUP_BUCKET=femvelle-backups

# Sentry
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
FRONTEND_SENTRY_DSN=https://your-frontend-sentry-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-org

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@femvelle.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@femvelle.com

# Stripe
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_PUBLIC_KEY=pk_live_your-stripe-public-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# WhatsApp
VITE_WHATSAPP_NUMBER=917609958608

# Monitoring
GRAFANA_PASSWORD=your-secure-grafana-password

# Admin
ADMIN_URL=secure-admin-url/

# Release
RELEASE_VERSION=1.0.0

# Deployment
PROD_HOST=your-production-server-ip
PROD_USER=deploy
PROD_SSH_KEY=your-ssh-private-key

# Notifications
WEBHOOK_URL=https://hooks.slack.com/your-webhook-url